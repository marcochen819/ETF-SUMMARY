      "source": [
        "import urllib.request as req\n",
        "import pandas as pd\n",
        "import time\n",
        "import json\n",
        "import random\n",
        "\n",
        "def get_twse_etf_data(date_str):\n",
        "    # 加上 f-string 才能把日期代入網址\n",
        "    url = f\"https://www.twse.com.tw/rwd/zh/fund/T86?response=json&date={date_str}&selectType=0099P\"\n",
        "\n",
        "    try:\n",
        "        resp = req.urlopen(url)\n",
        "        # urllib 需讀取後用 json.loads 轉譯\n",
        "        data = json.loads(resp.read().decode('utf-8'))\n",
        "\n",
        "        if data.get(\"stat\") == \"OK\":\n",
        "            df = pd.DataFrame(data[\"data\"], columns=data[\"fields\"])\n",
        "            selected_cols = [\"證券代號\", \"證券名稱\", \"外陸資買賣超股數(不含外資自營商)\",\n",
        "                             \"投信買賣超股數\", \"自營商買賣超股數\", \"三大法人買賣超股數\"]\n",
        "            df = df[selected_cols]\n",
        "            df.insert(0, '日期', date_str)\n",
        "            return df\n",
        "    except Exception as e:\n",
        "        print(f\"日期 {date_str} 抓取異常: {e}\")\n",
        "    return None\n",
        "\n",
        "# 設定區間\n",
        "start_date = \"2026-01-01\"\n",
        "end_date = \"2026-01-31\"\n",
        "date_list = pd.date_range(start=start_date, end=end_date, freq='B').strftime(\"%Y%m%d\")\n",
        "\n",
        "all_dfs = []\n",
        "\n",
        "for d in date_list:\n",
        "    print(f\"正在抓取 {d}...\", end=\" \")\n",
        "    res = get_twse_etf_data(d)\n",
        "\n",
        "    if res is not None:\n",
        "        all_dfs.append(res)\n",
        "        print(\"✅ 成功\")\n",
        "    else:\n",
        "        print(\"❌ 無資料 (休市)\")\n",
        "\n",
        "    # 將 sleep 移入迴圈內，保護 IP\n",
        "    sleep_time = random.uniform(3, 7)\n",
        "    time.sleep(sleep_time)\n",
        "\n",
        "# 合併輸出\n",
        "if all_dfs:\n",
        "    final_result = pd.concat(all_dfs, ignore_index=True)\n",
        "    final_result.to_csv(\"ETF_Summary.csv\", encoding=\"utf_8_sig\", index=False)\n",
        "    print(\"\\n任務完成！檔案已儲存。\")\n",
        "else:\n",
        "    print(\"\\n沒有抓到任何資料。\")"
      ]
